# To enable / disable self-hosting features.
SELF_HOSTED=false

# Market data provider for stock prices, exchange rates, and symbol search.
# Default: financialdata.net (300 calls/day free). Get a key: https://financialdata.net
FINANCIAL_DATA_API_KEY=

# To use Alpha Vantage instead (25 calls/day), uncomment below:
# MARKET_DATA_PROVIDER=alpha_vantage
# ALPHA_VANTAGE_API_KEY=yourapikeyhere

# Plaid — use "development" for real bank connections, "sandbox" only works with
# Plaid test credentials (user_good / pass_good). Production requires Plaid approval.
PLAID_CLIENT_ID=<user's key>
PLAID_SECRET=<user's key>
PLAID_ENV=development
# Redirect URI is required for OAuth-based institutions (many Canadian banks).
# Must be HTTPS and registered in your Plaid dashboard under Allowed redirect URIs.
# For local dev, use a tunnel (e.g. ngrok) and set the HTTPS URL here.
# PLAID_REDIRECT_URI=https://your-tunnel.ngrok-free.app/accounts

# SnapTrade
SNAPTRADE_CLIENT_ID=<user's key>
SNAPTRADE_CONSUMER_KEY=<user's key>

# GitHub — optional, raises rate limit from 60/hr to 5000/hr
# GITHUB_TOKEN=ghp_your_token_here
# GITHUB_REPO=RubenOussoren/roms-finance
