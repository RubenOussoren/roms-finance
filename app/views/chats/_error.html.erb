<%# locals: (chat:) %>

<div id="chat-error" class="px-3 py-2 bg-red-50 text-destructive border border-red-200 theme-dark:bg-red-900/20 theme-dark:text-red-400 theme-dark:border-red-800 rounded-lg">
  <% if chat.debug_mode? %>
    <div class="overflow-x-auto text-xs p-4 bg-red-100 theme-dark:bg-red-900/30 rounded-md mb-2">
      <code><%= chat.error %></code>
    </div>
  <% end %>

  <div class="flex items-center justify-between gap-2">
    <p class="text-xs text-destructive">Failed to generate response.  Please try again.</p>

    <%= render DS::Button.new(
      text: "Retry",
      href: retry_chat_path(chat),
    ) %>
  </div>
</div>
