<%= turbo_frame_tag "modal" do %>
  <%= render DS::Dialog.new do |dialog| %>
    <% dialog.with_header(title: "Recalibrate Mortgage Balance") %>
    <% dialog.with_body do %>
      <div class="space-y-4">
        <p class="text-sm text-secondary">
          Enter your current mortgage balance from your bank statement.
          This updates the baseline used to split the combined Plaid balance.
        </p>

        <%= styled_form_with url: account_recalibration_path(@account), scope: :recalibration, method: :post, class: "space-y-4" do |f| %>
          <div class="space-y-3">
            <%= f.number_field :balance, label: "Current mortgage balance",
                step: 0.01, min: 0, required: true,
                value: @account.balance %>

            <%= f.date_field :date, label: "As of date",
                value: Date.current %>
          </div>

          <div class="text-xs text-secondary">
            <p>After recalibration, future Plaid syncs will use this balance as the new starting point for amortization calculations.</p>
          </div>

          <%= f.submit "Recalibrate" %>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
