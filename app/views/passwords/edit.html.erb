<%
  header_title "Update Password"
%>

<%= styled_form_with model: Current.user, url: password_path, class: "space-y-4" do |form| %>
  <%= form.password_field :password_challenge, label: "Current Password", required: true, autocomplete: "current-password" %>
  <%= form.password_field :password, label: "New Password", required: true, autocomplete: "new-password" %>
  <%= form.password_field :password_confirmation, label: "Confirm New Password", required: true, autocomplete: "new-password" %>

  <%= form.submit "Reset Password" %>
<% end %>
