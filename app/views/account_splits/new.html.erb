<%= turbo_frame_tag "modal" do %>
  <%= render DS::Dialog.new do |dialog| %>
    <% dialog.with_header(title: "Split Mortgage + HELOC") %>
    <% dialog.with_body do %>
      <div class="space-y-4">
        <p class="text-sm text-secondary">
          Split "<%= @account.name %>" into separate mortgage and HELOC accounts.
          The HELOC balance will be derived automatically from Plaid's combined balance.
        </p>

        <%= styled_form_with url: account_split_path(@account), scope: :split, method: :post, class: "space-y-4" do |f| %>
          <fieldset class="space-y-3">
            <legend class="text-sm font-medium text-primary">Mortgage Details</legend>

            <%= f.date_field :origination_date, label: "Origination date", required: true %>

            <div class="flex items-center gap-2">
              <%= f.number_field :interest_rate, label: "Interest rate (%)",
                  step: 0.001, min: 0, required: true,
                  value: @account.accountable.interest_rate %>
              <%= f.select :rate_type, [["Fixed", "fixed"], ["Variable", "variable"]],
                  { label: "Rate type", selected: @account.accountable.rate_type || "fixed" } %>
            </div>

            <%= f.number_field :term_months, label: "Term (months)",
                min: 1, required: true,
                value: @account.accountable.term_months %>
          </fieldset>

          <%= render "shared/ruler", classes: "my-4" %>

          <fieldset class="space-y-3">
            <legend class="text-sm font-medium text-primary">HELOC Account</legend>

            <%= f.text_field :heloc_name, label: "HELOC account name",
                placeholder: "#{@account.name} HELOC" %>

            <%= f.number_field :heloc_balance, label: "Current HELOC balance",
                step: 0.01, min: 0, required: true %>
          </fieldset>

          <div class="text-xs text-secondary space-y-1">
            <p>After creating the split, Plaid syncs will automatically distribute the combined balance between the mortgage and HELOC.</p>
            <p>Use "Recalibrate" after prepayments to update the mortgage baseline.</p>
          </div>

          <%= f.submit "Create Split" %>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
